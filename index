<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@400;700;900&family=Old+Standard+TT:ital@1&display=swap" rel="stylesheet">
    
    <style>
        /* --- THEME VARIABLES --- */
        :root {
            --bg-color: #F8F5F0; /* Creamy off-white */
            --text-color: #1A1A1A;
            --card-bg: #FFFFFF;
            --nav-bg: rgba(248, 245, 240, 0.85);
            /* Retro / Poster Accents */
            --accent-red: #E63946;
            --accent-teal: #2A9D8F;
            --accent-orange: #E76F51;
            --accent-green: #6A8E7F;
            --dot-color: rgba(26, 26, 26, 0.15);
        }

        [data-theme="dark"] {
            --bg-color: #0A0A0A; /* Deep Poster Black */
            --text-color: #F8F5F0;
            --card-bg: #1A1A1A;
            --nav-bg: rgba(10, 10, 10, 0.85);
            --accent-red: #FF5A65;
            --accent-teal: #4CC9F0;
            --accent-orange: #F4A261;
            --accent-green: #8cb8a3;
            --dot-color: rgba(248, 245, 240, 0.15);
        }

        /* --- BASE STYLES --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            transition: background-color 0.4s ease, color 0.4s ease;
        }

        body {
            font-family: 'Libre Franklin', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 {
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -0.5px;
        }

        .italic-serif {
            font-family: 'Old Standard TT', serif;
            font-style: italic;
            text-transform: none;
            font-weight: normal;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        /* --- NAVIGATION --- */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 5%;
            background: var(--nav-bg);
            backdrop-filter: blur(10px);
            z-index: 1000;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            font-weight: 700;
            font-size: 0.9rem;
        }

        .nav-links a:hover {
            color: var(--accent-teal);
        }

        .theme-toggle {
            background: none;
            border: 2px solid var(--text-color);
            color: var(--text-color);
            padding: 0.5rem 1rem;
            font-family: 'Libre Franklin', sans-serif;
            font-weight: 700;
            cursor: pointer;
            border-radius: 50px;
            text-transform: uppercase;
            font-size: 0.8rem;
        }

        .theme-toggle:hover {
            background: var(--text-color);
            color: var(--bg-color);
        }

        /* --- HERO SECTION --- */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 5%;
            overflow: hidden;
        }

        .hero h1 {
            font-size: clamp(3rem, 8vw, 6rem);
            line-height: 1.1;
            z-index: 2;
        }

        .hero p {
            font-size: clamp(1.2rem, 3vw, 2rem);
            margin-top: 1rem;
            max-width: 600px;
            z-index: 2;
        }

        /* Responsive Visual Bits (Geometry & Patterns) */
        .shape {
            position: absolute;
            z-index: 1;
            transition: transform 0.3s ease-out;
        }

        .circle {
            width: 300px;
            height: 300px;
            background-color: var(--accent-red);
            border-radius: 50%;
            top: 15%;
            right: 10%;
            mix-blend-mode: multiply;
            animation: float 6s ease-in-out infinite;
        }

        [data-theme="dark"] .circle {
            mix-blend-mode: screen;
        }

        .dots {
            width: 200px;
            height: 200px;
            background-image: radial-gradient(var(--dot-color) 3px, transparent 3px);
            background-size: 20px 20px;
            bottom: 20%;
            left: 5%;
        }

        .wavy-line {
            width: 400px;
            height: 20px;
            background: repeating-radial-gradient(
                circle at 0 0, 
                transparent 0, var(--bg-color) 10px, transparent 10px, var(--accent-teal) 20px
            );
            bottom: 30%;
            right: 20%;
            opacity: 0.5;
        }

        /* --- RETRO STRIPES --- */
        .retro-stripes {
            width: 100%;
            height: 15px;
            background: linear-gradient(90deg, 
                var(--accent-orange) 0%, var(--accent-orange) 25%, 
                var(--accent-green) 25%, var(--accent-green) 50%, 
                var(--accent-teal) 50%, var(--accent-teal) 75%, 
                var(--accent-red) 75%, var(--accent-red) 100%);
            margin: 3rem 0;
        }

        /* --- SECTIONS & GRIDS --- */
        section {
            padding: 6rem 5%;
            position: relative;
        }

        .section-title {
            font-size: 2.5rem;
            margin-bottom: 3rem;
            display: inline-block;
            border-bottom: 4px solid var(--accent-orange);
            padding-bottom: 0.5rem;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        /* --- CARDS --- */
        .card {
            background: var(--card-bg);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
            position: relative;
        }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .card-img {
            width: 100%;
            height: 200px;
            background-color: var(--accent-teal);
            object-fit: cover;
        }

        /* Adding dummy patterns to cards to fit the aesthetic */
        .card-img.proj1 { background: linear-gradient(45deg, var(--accent-red), var(--accent-orange)); }
        .card-img.proj2 { background: radial-gradient(circle, var(--accent-teal), var(--accent-green)); }
        .card-img.proj3 { background-image: repeating-linear-gradient(45deg, var(--text-color) 0, var(--text-color) 2px, transparent 2px, transparent 8px); background-color: var(--accent-orange); }

        .card-content {
            padding: 1.5rem;
        }

        .card-category {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--accent-teal);
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .card-title {
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
        }

        /* --- ANIMATIONS --- */
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
            100% { transform: translateY(0px); }
        }

        /* --- RESPONSIVE DESIGN --- */
        @media (max-width: 768px) {
            .nav-links {
                display: none; /* In a full build, this would be a hamburger menu */
            }
            .circle {
                width: 150px;
                height: 150px;
            }
            .hero h1 {
                font-size: 3rem;
            }
        }
    </style>
</head>
<body>

    <nav>
        <div style="font-weight: 900; font-size: 1.2rem; text-transform: uppercase;">Portfolio.</div>
        <div class="nav-links">
            <a href="#about">About</a>
            <a href="#projects">Projects</a>
            <a href="#photography">Photography</a>
            <a href="#aviation">Aviation</a>
            <a href="#contact">Contact</a>
        </div>
        <button class="theme-toggle" id="theme-btn">Dark Mode</button>
    </nav>

    <header class="hero" id="about">
        <div class="shape circle" id="hero-circle"></div>
        <div class="shape dots" id="hero-dots"></div>
        <div class="shape wavy-line"></div>

        <h1>Hello, I'm <br><span style="color: var(--accent-teal);">Your Name</span>.</h1>
        <p class="italic-serif">I build responsive websites, capture moments through photography, and explore the skies.</p>
    </header>

    <div class="retro-stripes"></div>

    <section id="projects">
        <h2 class="section-title">Recent Projects</h2>
        <div class="grid">
            <div class="card">
                <div class="card-img proj1"></div>
                <div class="card-content">
                    <div class="card-category">Web Development</div>
                    <h3 class="card-title">Creative Engineering</h3>
                    <p class="italic-serif">Solving creative problems with code and bold design.</p>
                </div>
            </div>
            <div class="card">
                <div class="card-img proj2"></div>
                <div class="card-content">
                    <div class="card-category">Hardware</div>
                    <h3 class="card-title">Interactive Lights</h3>
                    <p class="italic-serif">Letting the internet interact with my environment.</p>
                </div>
            </div>
            <div class="card">
                <div class="card-img proj3"></div>
                <div class="card-content">
                    <div class="card-category">Design</div>
                    <h3 class="card-title">Bauhaus Poster</h3>
                    <p class="italic-serif">A study in typography and geometric shapes.</p>
                </div>
            </div>
        </div>
    </section>

    <div class="retro-stripes" style="flex-direction: row-reverse;"></div>

    <section id="photography">
        <h2 class="section-title">Photography & Aviation</h2>
        <div class="grid">
            <div class="card" style="background: var(--bg-color); border: 2px solid var(--text-color); box-shadow: none;">
                <div class="card-content">
                    <h3 class="card-title" style="font-size: 2rem;">Capturing the World</h3>
                    <p class="italic-serif" style="margin-top: 1rem;">Whether through a lens or from the cockpit, this is where my visual work lives.</p>
                    <br>
                    <a href="#contact" style="color: var(--accent-red); font-weight: 700; text-transform: uppercase;">View Gallery &rarr;</a>
                </div>
            </div>
            <div class="card"><div class="card-img" style="background-color: var(--accent-brown); height: 100%;"></div></div>
            <div class="card"><div class="card-img" style="background-color: #333; height: 100%;"></div></div>
        </div>
    </section>

    <footer id="contact" style="padding: 4rem 5%; text-align: center; border-top: 1px solid var(--dot-color);">
        <h2 style="margin-bottom: 1rem;">Let's Build Something</h2>
        <p class="italic-serif" style="margin-bottom: 2rem;">Looking to innovate? Get in touch.</p>
        <a href="mailto:your@email.com" style="background: var(--text-color); color: var(--bg-color); padding: 1rem 2rem; border-radius: 50px; font-weight: 700; text-transform: uppercase;">Contact Me</a>
    </footer>

    <script>
        // --- Theme Toggle Logic ---
        const themeBtn = document.getElementById('theme-btn');
        const root = document.documentElement;
        
        // Check local storage for theme preference
        const currentTheme = localStorage.getItem('theme') || 'light';
        if (currentTheme === 'dark') {
            root.setAttribute('data-theme', 'dark');
            themeBtn.textContent = 'Light Mode';
        }

        themeBtn.addEventListener('click', () => {
            let theme = root.getAttribute('data-theme');
            if (theme === 'dark') {
                root.removeAttribute('data-theme');
                localStorage.setItem('theme', 'light');
                themeBtn.textContent = 'Dark Mode';
            } else {
                root.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
                themeBtn.textContent = 'Light Mode';
            }
        });

        // --- Interactive Mouse Parallax Effect ---
        document.addEventListener('mousemove', (e) => {
            const mouseX = e.clientX / window.innerWidth;
            const mouseY = e.clientY / window.innerHeight;

            const circle = document.getElementById('hero-circle');
            const dots = document.getElementById('hero-dots');

            // Subtle movement based on mouse position
            if(circle && dots) {
                circle.style.transform = `translate(${mouseX * -30}px, ${mouseY * -30}px)`;
                dots.style.transform = `translate(${mouseX * 20}px, ${mouseY * 20}px)`;
            }
        });
    </script>
</body>
</html>
